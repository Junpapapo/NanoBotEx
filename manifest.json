{
  "manifest_version": 3,
  "name": "NanoBot - On-Device AI Chatbot",
  "version": "1.0.0",
  "description": "어느 페이지에서든 나만의 AI 페르소나 및 온디바이스 AI와 대화하세요.",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://*.googleapis.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": "nanobots/bot-01.webp"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "js": ["src/content/index.tsx"],
      "matches": ["<all_urls>"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "src/index.css", "nanobots/*", "launchers/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
