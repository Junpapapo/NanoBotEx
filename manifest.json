{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "default_locale": "ko",
  "version": "1.0.0",
  "description": "__MSG_appDesc__",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png",
    "512": "icons/icon512.png"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://*.googleapis.com/*",
    "http://127.0.0.1:5001/*",
    "http://localhost:5001/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "src/index.css", "nanobots/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
